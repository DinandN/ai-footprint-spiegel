{
  "name": "ai-footprint-spiegel",
  "version": "0.1.0",
  "private": true,
  "description": "AI Footprint Spiegel — monorepo: Nuxt front-end + Express back-end",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "pull-models": "node scripts/pullModels.mjs",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently -k -n backend,frontend -c blue,green npm:dev:backend npm:dev:frontend"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
