# Copy to .env and fill in. The .env file is never committed (see .gitignore).
# Providers are mocked in this first version, so keys may stay empty for now.

# Server
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# External AI providers (server-side only — never exposed to the front-end)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Local Ollama interface (no key needed, local only)
OLLAMA_HOST=http://localhost:11434
